{
  "name": "@clawdi-cloud/cli",
  "version": "0.0.1",
  "description": "iCloud for AI Agents — cross-agent sessions, skills, memory, and vault.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "clawdi": "./bin/clawdi.mjs"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun && cp -r skills dist/skills",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Clawdi-AI/clawdi-cloud.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Clawdi-AI/clawdi-cloud/issues"
  },
  "homepage": "https://github.com/Clawdi-AI/clawdi-cloud#readme",
  "keywords": [
    "cli",
    "claude-code",
    "codex",
    "openclaw",
    "hermes",
    "ai-agents",
    "skills",
    "memory",
    "vault",
    "mcp"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "tar": "^7.5.13",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clawdi-cloud/shared": "workspace:*",
    "@types/bun": "^1.3.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
