{
  "name": "@clawdi-cloud/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "clawdi": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun && sed -i '' '1s|#!/usr/bin/env node|#!/usr/bin/env bun|' dist/index.js && cp -r skills dist/skills",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@clawdi-cloud/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",

    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ora": "^8.2.0",
    "tar": "^7.5.13",
    "zod": "^4.3.6"
  },
  "devDependencies": {

    "@types/bun": "^1.3.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
